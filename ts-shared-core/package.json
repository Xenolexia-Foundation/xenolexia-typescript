{
  "name": "xenolexia-typescript",
  "version": "0.1.0",
  "description": "Shared core logic for Xenolexia (React Native, Electron). Platform-agnostic types, algorithms, and services with injectable I/O.",
  "author": "Husain Alamri (H4n) and Xenolexia Foundation",
  "license": "AGPL-3.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.ts --fix",
    "lint:check": "eslint . --ext .js,.ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "fetch:translations": "node scripts/fetch-translations.js",
    "build:translations": "node scripts/build-words-from-translations.js",
    "find:mymemory-warning": "node scripts/find-mymemory-warning-languages.js",
    "ensure:translations-resolved": "node scripts/ensure-translations-resolved.js",
    "run:every-4h-until-resolved": "node scripts/run-every-4h-until-resolved.js"
  },
  "dependencies": {
    "@lingo-reader/mobi-parser": "^0.4.5",
    "date-fns": "^3.6.0",
    "epubjs": "^0.3.93",
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "uuid": "^10.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
